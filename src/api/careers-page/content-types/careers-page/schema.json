{
  "kind": "singleType",
  "collectionName": "careers_page",
  "info": {
    "singularName": "careers-page",
    "pluralName": "careers-pages",
    "displayName": "Careers Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "hero_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "jobs_external_url": {
      "type": "string"
    },
    "mission_vision": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": { "preset": "defaultHtml" },
      "placeholder": "Unified mission and vision statement"
    },
    "values": {
      "type": "component",
      "repeatable": true,
      "component": "careers.value-item"
    },
    "benefits_intro": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": { "preset": "defaultHtml" }
    },
    "benefits": {
      "type": "component",
      "repeatable": true,
      "component": "careers.benefit-item"
    },
    "laboratory_tour_text": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": { "preset": "defaultHtml" }
    }
  }
}
