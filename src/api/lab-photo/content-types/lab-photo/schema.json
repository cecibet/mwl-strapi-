{
  "kind": "collectionType",
  "collectionName": "lab_photos",
  "info": {
    "singularName": "lab-photo",
    "pluralName": "lab-photos",
    "displayName": "Lab Photo"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
